---
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL.slice(0, -1)
  : import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>OpenQuant Documentation</title>
    <meta http-equiv="refresh" content={`0; url=${base}/quickstart`} />
  </head>
  <body>
    <p>Redirecting to <a href={`${base}/quickstart`}>Quickstart</a>...</p>
  </body>
</html>
