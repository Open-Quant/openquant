---
import Layout from "../layouts/Layout.astro";
import { apiInventory } from "../data/apiInventory";

const rustModules = Object.entries(apiInventory.rust).sort(([a], [b]) => a.localeCompare(b));
const pythonModules = Object.entries(apiInventory.python).sort(([a], [b]) => a.localeCompare(b));
---
<Layout title="API Reference • OpenQuant-rs" description="Subject-oriented API reference with generated inventory snapshots.">
  <section class="hero">
    <h1>API by Subject</h1>
    <p class="muted">Curated entry points grouped by workflow, plus generated Rust/Python inventories to prevent stale docs drift.</p>
  </section>

  <h2>1. Event-Driven Data and Labeling</h2>
  <ul>
    <li><code>data_structures::standard_bars</code>, <code>data_structures::time_bars</code>, <code>data_structures::run_bars</code>, <code>data_structures::imbalance_bars</code></li>
    <li><code>filters::cusum_filter_indices</code>, <code>filters::cusum_filter_timestamps</code>, <code>filters::z_score_filter_indices</code></li>
    <li><code>labeling::triple_barrier_events</code>, <code>labeling::triple_barrier_labels</code>, <code>labeling::meta_labels</code></li>
    <li><code>sample_weights::get_weights_by_return</code>, <code>sample_weights::get_weights_by_time_decay</code></li>
  </ul>

  <h2>2. Sampling, Validation and ML Diagnostics</h2>
  <ul>
    <li><code>sampling::seq_bootstrap</code>, <code>sampling::get_ind_matrix</code>, <code>sampling::get_ind_mat_average_uniqueness</code></li>
    <li><code>cross_validation::PurgedKFold</code>, <code>cross_validation::ml_get_train_times</code></li>
    <li><code>feature_importance::mean_decrease_impurity</code>, <code>feature_importance::mean_decrease_accuracy</code>, <code>feature_importance::single_feature_importance</code></li>
    <li><code>openquant.feature_diagnostics.mdi_importance</code>, <code>mda_importance</code>, <code>sfi_importance</code>, <code>substitution_effect_report</code></li>
  </ul>

  <h2>3. Position Sizing and Trade Construction</h2>
  <ul>
    <li><code>bet_sizing::bet_size_probability</code>, <code>bet_sizing::bet_size_dynamic</code>, <code>bet_sizing::bet_size_budget</code>, <code>bet_sizing::bet_size_reserve</code></li>
    <li><code>etf_trick::EtfTrick</code>, <code>etf_trick::get_futures_roll_series</code></li>
  </ul>

  <h2>4. Portfolio Construction and Risk</h2>
  <ul>
    <li><code>portfolio_optimization::allocate_inverse_variance</code>, <code>allocate_min_vol</code>, <code>allocate_max_sharpe</code></li>
    <li><code>cla::CLA</code>, <code>hrp::HierarchicalRiskParity</code>, <code>hcaa::HierarchicalClusteringAssetAllocation</code>, <code>onc::get_onc_clusters</code></li>
    <li><code>RiskMetrics::calculate_value_at_risk</code>, <code>RiskMetrics::calculate_expected_shortfall</code>, <code>RiskMetrics::calculate_conditional_drawdown_risk</code></li>
  </ul>

  <h2>5. Market Microstructure, Dependence and Regime Detection</h2>
  <ul>
    <li><code>microstructural_features::get_roll_measure</code>, <code>get_corwin_schultz_estimator</code>, <code>get_bekker_parkinson_vol</code></li>
    <li><code>codependence::distance_correlation</code>, <code>codependence::get_mutual_info</code>, <code>codependence::variation_of_information_score</code></li>
    <li><code>structural_breaks::get_chow_type_stat</code>, <code>get_chu_stinchcombe_white_statistics</code>, <code>get_sadf</code></li>
  </ul>

  <h2>Generated Rust Inventory</h2>
  <p class="muted">Source: <code>scripts/generate_api_inventory.py</code> → <code>docs-site/src/data/apiInventory.ts</code></p>
  {rustModules.map(([module, functions]) => (
    <article class="card">
      <h3><code>{module}</code></h3>
      <p>{functions.join(", ")}</p>
    </article>
  ))}

  <h2>Generated Python Inventory</h2>
  {pythonModules.map(([module, functions]) => (
    <article class="card">
      <h3><code>openquant.{module}</code></h3>
      <p>{functions.join(", ")}</p>
    </article>
  ))}

  <h2>Inventory Check</h2>
  <pre><code class="language-bash">python3 scripts/generate_api_inventory.py
python3 scripts/generate_api_inventory.py --check</code></pre>
</Layout>
