---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL.slice(0, -1)
  : import.meta.env.BASE_URL;
---
<Layout title="Guides • OpenQuant-rs" description="Concept and operational guides for OpenQuant-rs workflows.">
  <section class="hero">
    <h1>Guides</h1>
    <p class="muted">Conceptual and operational docs for daily quant research and productionization.</p>
  </section>

  <div class="grid">
    <article class="card">
      <h3><a href={`${base}/modules`}>AFML Subject Map</a></h3>
      <p>Chapter-oriented mapping from AFML domains to implementation modules.</p>
    </article>
    <article class="card">
      <h3><a href={`${base}/module`}>Module Pages</a></h3>
      <p>Detailed formulas, implementation notes, and code snippets by module.</p>
    </article>
    <article class="card">
      <h3><a href={`${base}/notebook-research-workflow`}>Notebook Workflow</a></h3>
      <p>Promotion gates, anti-leakage controls, and reproducibility checks.</p>
    </article>
    <article class="card">
      <h3><a href={`${base}/performance`}>Performance Guide</a></h3>
      <p>Benchmark protocol, thresholds, and regression workflow.</p>
    </article>
    <article class="card">
      <h3><a href={`${base}/publishing`}>Publishing Guide</a></h3>
      <p>Release checklist and versioning policy.</p>
    </article>
  </div>
</Layout>
