---
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL.slice(0, -1)
  : import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Quickstart • OpenQuant</title>
    <meta name="description" content="First-run OpenQuant validation commands and next steps." />
    <style>
      body { font-family: ui-monospace, Menlo, Consolas, monospace; margin: 2rem auto; max-width: 900px; line-height: 1.5; }
      pre { background: #0e1726; color: #e9f1ff; padding: 1rem; overflow-x: auto; border-radius: 8px; }
      a { color: #0e5aa7; }
    </style>
  </head>
  <body>
    <h1>Quickstart</h1>
    <p>Run the baseline validation path before deeper workflow docs.</p>
    <pre><code>cargo test --workspace --lib --tests --all-features -- --skip test_sadf_test
cargo test -p openquant --test structural_breaks test_sadf_test -- --ignored
cd docs-site
bun run check:docs</code></pre>
    <p>Next: <a href={`${base}/getting-started`}>Environment Setup</a> and <a href={`${base}/module`}>Module Pages</a>.</p>
  </body>
</html>
